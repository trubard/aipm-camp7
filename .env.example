# 환경 변수 예시
# 실제 값은 로컬 .env 와 Vercel 프로젝트 환경변수에 설정하세요.
# .env 는 절대 커밋하지 않습니다(.gitignore 로 제외됨).

# (필수) Anthropic Claude API 키 — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# (선택) HMAC 봇 마찰 토큰용 시크릿.
# 설정하면 /api/token 발급 + /api/chat 검증이 활성화됩니다(미설정 시 해당 검증은 건너뜀).
# 임의의 긴 랜덤 문자열 권장: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# (선택) Sentry DSN — 설정하면 프론트·백엔드 에러 모니터링이 켜집니다.
# Sentry 프로젝트 → Settings → Client Keys (DSN)
SENTRY_DSN=
